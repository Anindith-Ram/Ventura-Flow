# ============================================================
# Research Intelligence Pipeline — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# --- OpenAlex (primary ingestion source; no key required) ---
OPENALEX_EMAIL=your@email.com

# --- OpenAI-compatible endpoint (local OSS models recommended) ---
# Leave empty if your local endpoint does not require auth.
OPENAI_API_KEY=
# Default local endpoint for Ollama OpenAI-compatible API:
OPENAI_BASE_URL=http://localhost:11434/v1

# --- Embeddings ---
# Options: "fastembed" (local, default) | "openai"
EMBEDDING_BACKEND=fastembed
# fastembed model (384-dim, ~130MB download on first use):
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
# For openai backend (OpenAI-compatible local endpoint), model name:
OPENAI_EMBEDDING_MODEL=nomic-embed-text
# LLM used for novelty/IP/value paper scoring (OSS default):
OPENAI_SCORING_MODEL=llama3.1:8b-instruct-q4_K_M

# --- Vector Store (Qdrant) ---
# Leave blank to use in-memory mode (default, no Docker needed).
# For persistence: run `docker run -p 6333:6333 qdrant/qdrant` then set URL.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=papers

# --- Structured Metadata (SQLite) ---
DB_PATH=./data/papers.db

# --- Pipeline ---
# Investor relevance score threshold to trigger PDF OCR (0.0–1.0)
OCR_SCORE_THRESHOLD=0.6
# Minimum novelty/value score required to move paper to next stage.
PAPER_PASS_THRESHOLD=0.65
# First try direct PDF text extraction from embedded text layer.
# Enable OCR fallback only when needed (more compute-intensive).
OCR_FALLBACK_ENABLED=false
# Max pages to scan for direct text extraction.
PDF_TEXT_MAX_PAGES=20
# Directory for downloaded PDFs
PDF_DOWNLOAD_DIR=./data/pdfs

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
