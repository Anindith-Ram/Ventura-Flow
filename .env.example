# ============================================================
# Research Intelligence Pipeline — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# --- Semantic Scholar API ---
# Free tier: ~100 req/5min. Get a key at https://www.semanticscholar.org/product/api
S2_API_KEY=

# --- OpenAlex (no key required; polite pool: add your email) ---
OPENALEX_EMAIL=your@email.com

# --- OpenAI (optional: for embeddings and/or LLM scoring) ---
OPENAI_API_KEY=
# Set to override embedding endpoint (OpenAI-compatible, e.g. Ollama):
OPENAI_BASE_URL=

# --- Embeddings ---
# Options: "fastembed" (local, default) | "openai"
EMBEDDING_BACKEND=fastembed
# fastembed model (384-dim, ~130MB download on first use):
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
# For openai backend, model name:
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Vector Store (Qdrant) ---
# Leave blank to use in-memory mode (default, no Docker needed).
# For persistence: run `docker run -p 6333:6333 qdrant/qdrant` then set URL.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=papers

# --- Structured Metadata (SQLite) ---
DB_PATH=./data/papers.db

# --- Pipeline ---
# Investor relevance score threshold to trigger PDF OCR (0.0–1.0)
OCR_SCORE_THRESHOLD=0.6
# Directory for downloaded PDFs
PDF_DOWNLOAD_DIR=./data/pdfs

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
